message EmptyResponse {
}

message TokenResponse {
  1 -> string token;
}

message SuccessResponse {
  1 -> bool success;
  2 -> string error;
  3 -> string supportCode;
}

message ProductRecord {
  1 -> string id;
  2 -> string name;
  3 -> string collaboratorName;
  4 -> string productUrl;
}

message ProductsResponse {
  1 -> ProductRecord[] products;
  2 -> string error;
}
