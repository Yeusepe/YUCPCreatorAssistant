    "@opentelemetry/resources": "^1.30.1",
    "@opentelemetry/sdk-trace-base": "^1.30.1",
    "@tempojs/common": "^0.0.12"
  },
  "devDependencies": {
    "@types/bun": "^1.1.0",
    "bun-types": "^1.1.0"
  }
