{
  "name": "@yucp/shared",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./crypto": "./src/crypto.ts",
    "./*": "./src/*.ts",
    "./test/loadBotE2ESecrets": "./test/loadBotE2ESecrets.ts",
    "./test/loadTestSecrets": "./test/loadTestSecrets.ts"
  },
  "scripts": {
    "build": "tsc",
    "lint": "biome check .",
