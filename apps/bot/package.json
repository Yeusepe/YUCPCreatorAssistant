{
  "name": "@yucp/bot",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun run --watch src/index.ts",
    "start": "bun run src/index.ts",
    "build": "tsc",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "test:ci": "bun test --coverage"
  },
  "dependencies": {
    "@yucp/providers": "workspace:*",
    "@yucp/shared": "workspace:*",
    "convex": "^1.32.0",
    "discord.js": "^14.15.0",
    "posthog-node": "^5.26.2"
  },
  "devDependencies": {
    "@infisical/sdk": "^4.0.6",
    "@types/bun": "^1.1.0",
    "bun-types": "^1.1.0"
  }
}
