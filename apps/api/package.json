{
  "name": "@yucp/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun run --watch src/index.ts",
    "start": "bun run src/index.ts",
    "build": "bun run build:docs:index && tsc",
    "build:docs:index": "vite build --config vite.docs-index.config.ts",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "typecheck": "tsc --noEmit",
    "test": "bun test ./src",
    "test:ci": "bun test ./src --coverage",
    "test:e2e": "cross-env TEST_BASE_URL=http://localhost:3001 npx playwright test --config playwright.config.ts",
    "test:e2e:list": "npx playwright test --config playwright.config.ts --list"
  },
  "dependencies": {
    "@convex-dev/better-auth": "^0.11.0",
    "@infisical/sdk": "^4.0.6",
    "@react-email/components": "^0.0.30",
    "@react-three/drei": "^10.7.6",
    "@react-three/fiber": "^9.4.0",
    "@tempojs/cloudflare-worker-router": "^0.0.12",
    "@tempojs/common": "^0.0.12",
    "@yucp/application": "workspace:*",
    "@yucp/private-rpc": "workspace:*",
    "@yucp/providers": "workspace:*",
    "@yucp/shared": "workspace:*",
    "bebop": "3.0.4",
    "better-auth": "1.5.5",
    "canvas-confetti": "^1.9.3",
    "convex": "^1.32.0",
    "facehash": "^0.1.0",
    "holographic-sticker": "^1.0.4",
    "ioredis": "^5.4.1",
    "lucide": "^0.577.0",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "resend": "^4.0.0",
    "tailwindcss": "^4.1.12",
    "three": "^0.179.1",
    "vite": "^7.1.3"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.0",
    "@vitejs/plugin-react": "^5.0.0",
    "@types/bun": "^1.1.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "bun-types": "^1.1.0"
  }
}
