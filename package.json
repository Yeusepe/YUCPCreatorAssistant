{
  "name": "yucp-creator-assistant",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "lint": "bun run --filter '*' lint",
    "typecheck": "bun run --filter '*' typecheck",
    "test": "bun run --filter '*' test",
    "test:infisical": "bun run --env-file=.env.infisical test",
    "test:ci": "bun run --filter '*' test:ci",
    "build": "bun run --filter '*' build",
    "dev": "concurrently -n convex,api,bot,tunnel -c blue,magenta,green,cyan \"npx convex dev\" \"bun run dev:api\" \"bun run dev:bot\" \"tailscale funnel 3001\"",
    "dev:infisical": "bun run sync:convex:env && concurrently -n convex,api,bot,tunnel -c blue,magenta,green,cyan \"npx convex dev\" \"bun run dev:api:infisical\" \"bun run dev:bot:infisical\" \"tailscale funnel 3001\"",
    "sync:convex:env": "bun run --env-file=.env.infisical ops/sync-convex-env.ts",
    "sync:convex:env:prod": "bun run --env-file=.env.infisical ops/sync-convex-env.ts --prod",
    "dev:api": "bun run --watch apps/api/src/index.ts",
    "dev:api:infisical": "bun run --env-file=.env.infisical dev:api",
    "dev:bot": "bun run --watch apps/bot/src/index.ts",
    "dev:bot:infisical": "bun run --env-file=.env.infisical dev:bot",
    "convex:dev": "npx convex dev",
    "convex:deploy": "npx convex deploy",
    "start:api:infisical": "cross-env INFISICAL_ENV=prod bun run --filter @yucp/api start",
    "start:bot:infisical": "cross-env INFISICAL_ENV=prod bun run --filter @yucp/bot start",
    "start:all": "concurrently -k \"bun run --filter @yucp/api start\" \"bun run --filter @yucp/bot start\""
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@biomejs/biome": "^1.9.0",
    "concurrently": "^9.1.0",
    "cross-env": "^7.0.3",
    "@infisical/sdk": "^4.0.6",
    "bun-types": "^1.1.0",
    "typescript": "^5.3.0"
  },
  "engines": {
    "node": ">=18",
    "bun": ">=1.1"
  },
  "dependencies": {
    "@convex-dev/better-auth": "^0.10.13",
    "better-auth": "1.4.9",
    "convex": "^1.32.0"
  }
}